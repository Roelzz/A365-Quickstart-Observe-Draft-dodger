# Python Agent Framework - Environment Template
# Copy this file to .env and fill in the values

# =============================================================================
# Azure OpenAI Configuration
# =============================================================================
# COMPATIBLE MODELS (tested working with Agent Framework SDK):
#   - gpt-4.1           (recommended, best balance of capability and speed)
#   - gpt-4o            (fast, good for development)
#   - gpt-4o-mini       (cheapest, good for testing)
#
# INCOMPATIBLE MODELS (do NOT use):
#   - gpt-5.4-pro       (reasoning model — uses Responses API, not Chat Completions)
#   - o1, o1-mini, o3   (reasoning models — same issue)
#
# The Agent Framework SDK requires models that support the Chat Completions API.
# Reasoning models use the Responses API which is incompatible.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# =============================================================================
# Microsoft Agents SDK Service Connection Configuration
# These come from a365 setup — fill in after running a365 setup all
# =============================================================================
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTID=<BLUEPRINT_ID>
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTSECRET=<CLIENT_SECRET>
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__TENANTID=<TENANT_ID>
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__SCOPES=5a807f24-c9de-44ee-a3a7-329e88a00ffc/.default

# Connection mapping
CONNECTIONSMAP_0_SERVICEURL=*
CONNECTIONSMAP_0_CONNECTION=SERVICE_CONNECTION

# Auth handler (leave empty for anonymous/local testing, set to AGENTIC for production)
AUTH_HANDLER_NAME=

# =============================================================================
# Bot Authentication (for JWT validation of incoming messages)
# CRITICAL: Without these, the container runs in anonymous mode and MCP calls fail
# Fill in after a365 setup all completes
# =============================================================================
CLIENT_ID=<BLUEPRINT_ID>
CLIENT_SECRET=<CLIENT_SECRET>
TENANT_ID=<TENANT_ID>

# For local development with token from a365 CLI
#BEARER_TOKEN=your-token

# Server Configuration
PORT=3978

# =============================================================================
# Agentic Auth (required for MCP server access in production)
# =============================================================================
#USE_AGENTIC_AUTH=true
#AGENT_ID=<BLUEPRINT_ID>
#AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__AGENTIC__SETTINGS__TYPE=AgenticUserAuthorization
#AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__AGENTIC__SETTINGS__ALT_BLUEPRINT_NAME=SERVICE_CONNECTION
#AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__AGENTIC__SETTINGS__SCOPES=https://graph.microsoft.com/.default
#CONNECTIONSMAP__0__SERVICEURL=*
#CONNECTIONSMAP__0__CONNECTION=SERVICE_CONNECTION

# =============================================================================
# Telemetry (optional)
# =============================================================================
# Local OTLP exporter (Aspire Dashboard): set to http://localhost:4317 when running dashboard
OTEL_EXPORTER_OTLP_ENDPOINT=
# Azure Monitor / Application Insights (persistent cloud telemetry)
APPLICATIONINSIGHTS_CONNECTION_STRING=
