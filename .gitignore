# Virtual environment
.venv/
venv/
ENV/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Environment file with secrets
.env
.env.*backup*

# IDE
.vscode/
.idea/
*.swp
*.swo

# Build artifacts
*.egg-info/
dist/
build/
*.egg

# Logs
*.log
logs/

# Local config (contains secrets)
*.local.json

# Deployment artifacts (contain tenant-specific values)
deployment.json
a365.config.json
a365.generated.config.json
demo-tenant.config.json

# Manifest build output
deployment script/manifest/*.zip
# a365 publish writes the project-root manifest/ folder per fork.
# It contains the user's blueprint ID and agentic-template UUID — must not be committed.
manifest/*.json
manifest/*.zip

# MOS token
/tmp/mos_token.txt

# Purview Audit query results (per-run JSONL dumps from scripts/query-audit.sh — contain tenant + agent telemetry)
audit-results/

# Local git worktrees — project-local convention (cd .worktrees/<branch>/ to test in-flight branches)
.worktrees/

# Personal demo runbook (contains tenant-specific IDs, paths)
demo.md
